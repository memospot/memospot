    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tailwindcss/postcss": "4.2.1",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-shell": "2.3.5",
    "@types/node": "24.10.13",
    "bits-ui": "0.22.0",
